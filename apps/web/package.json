{
  "name": "@readsmith/web",
  "version": "0.0.0",
  "license": "FSL-1.1-MIT",
  "private": true,
  "type": "module",
  "description": "The Readsmith serving and island-hydration shell (Next.js). Serves prebuilt pages; it is not the MDX compiler.",
  "scripts": {
    "predev": "node scripts/copy-assets.mjs && node scripts/build-content.mjs",
    "dev": "next dev -p 4321",
    "prebuild": "node scripts/copy-assets.mjs && node scripts/build-content.mjs",
    "build": "next build",
    "start": "next start -p 4321",
    "ai:index": "node scripts/ai-index.mjs",
    "ai:reindex": "node scripts/ai-index.mjs --reindex",
    "skill:generate": "node scripts/generate-skill.mjs",
    "site:build": "node scripts/site-build.mjs",
    "site:rollback": "node scripts/site-rollback.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/spectral": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@readsmith/ai": "workspace:*",
    "@readsmith/api": "workspace:*",
    "@readsmith/api-reference": "workspace:*",
    "@readsmith/build": "workspace:*",
    "@readsmith/cache": "workspace:*",
    "@readsmith/components": "workspace:*",
    "@readsmith/config": "workspace:*",
    "@readsmith/db": "workspace:*",
    "@readsmith/git": "workspace:*",
    "@readsmith/mdx": "workspace:*",
    "@readsmith/model": "workspace:*",
    "@readsmith/storage": "workspace:*",
    "hono": "^4.12.28",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
