# Readsmith self-host configuration. Copy to `.env` and adjust.
# Without DATABASE_URL the app runs docs-only (zero external services). Set it to
# activate the persistence backbone (API reference, search, jobs).

# --- Database (required only for the persistence backbone) ---
POSTGRES_USER=readsmith
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=readsmith
# The app reads DATABASE_URL; docker-compose composes it from the values above.
# For a non-compose run, set it directly, e.g.:
# DATABASE_URL=postgres://readsmith:change-me-in-production@localhost:5432/readsmith

# --- App ---
# Host port the app is published on.
PORT=4321
# Path to your docs content (mounted read-only into the container).
READSMITH_CONTENT=/content
# Filesystem root for stored spec blobs (mounted volume in compose).
READSMITH_STORAGE_ROOT=/storage
# Worker concurrency and log level (optional).
# READSMITH_WORKER_CONCURRENCY=2
# READSMITH_LOG_LEVEL=info

# --- Content bundle store (the precompiled site artifact) ---
# Where the serving shell reads the compiled bundle from. Defaults work with no
# config: the local filesystem driver rooted at apps/web/.readsmith.
# STORAGE_DRIVER=local
# STORAGE_ROOT=/var/lib/readsmith/bundle
# Reserved for the hosted phase (S3-compatible / Cloudflare R2); not read in v1:
# STORAGE_DRIVER=s3
# STORAGE_ENDPOINT=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
