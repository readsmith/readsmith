{
  "name": "@readsmith/components",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The Readsmith component library and reading shell: design tokens, in-content components, and island hydration.",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./styles/index.css",
    "./styles/tokens.css": "./styles/tokens.css"
  },
  "files": ["dist", "styles"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@readsmith/mdx": "workspace:*",
    "hastscript": "^9.0.1"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "happy-dom": "^15.11.0"
  }
}
