    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@readsmith/mdx": "workspace:*",
    "@readsmith/model": "workspace:*",
    "hast-util-from-html": "^2.0.3",
    "hastscript": "^9.0.1",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "happy-dom": "^20.8.9"
