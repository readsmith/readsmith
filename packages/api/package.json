{
  "name": "@readsmith/api",
  "version": "0.0.0",
  "license": "FSL-1.1-MIT",
  "private": true,
  "type": "module",
  "description": "The portable Hono API: routes plus a dependency contract, runtime-agnostic (Node or edge). Hosts inject a database and other services.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@readsmith/exec": "workspace:*",
    "@readsmith/model": "workspace:*",
    "hono": "^4.6.14",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@readsmith/cache": "workspace:^"
  }
}
