{
  "name": "@readsmith/build",
  "version": "0.0.0",
  "license": "FSL-1.1-MIT",
  "private": true,
  "type": "module",
  "description": "The site compile: one deterministic path from a content directory to the immutable bundle and its static-asset plan.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
