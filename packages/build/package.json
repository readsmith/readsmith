    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@readsmith/api-reference": "workspace:*",
    "@readsmith/components": "workspace:*",
    "@readsmith/config": "workspace:*",
    "@readsmith/mdx": "workspace:*",
    "@readsmith/model": "workspace:*",
    "@readsmith/storage": "workspace:*",
    "zod": "^4.0.5"
  }
}
